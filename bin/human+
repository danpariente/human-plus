#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/human_plus"

def usage
  puts <<~USAGE
    human+ — the mind as a programmable system (after Hawkins, "Letting Go")

    Usage:
      human+ map                      Print the Map of Consciousness
      human+ npc                      Assemble the default human; list its firmware
      human+ experience "<stimulus>"  Feed a stimulus to an NPC: feeling -> thoughts -> response
      human+ mind <feeling> [n]       Print n thoughts the feeling generates (default 10)
      human+ test [file.csv]          Run stimuli test cases (default data/stimuli.csv)
      human+ surrender <feeling>      Interactive: stay with the feeling until it runs out
      human+ emancipate               The full pathway: surrender everything below Courage
      human+ town ["<stimulus>" [n]]  n ticks of Smallville on the Map: reactions become
                                      the next tick's stimuli (after arXiv 2304.03442)
                    --generative      perception generated by Claude instead of the CSV
                                      (needs the anthropic gem and an API key)
                    --chart[=f.html]  also write the run as a self-contained HTML page
                                      (calibration, pressure, the grudge ledger)
      human+ converse [a b ["<stimulus>" [n]]]
                                      two residents at close range: the words are the
                                      Mind aloud; the listener responds to the tone
                                      (--generative works here too)
      human+ live ["<stimulus>"]      first person: you are settled into the town, and
                                      when a program of yours fires you get the question
                                      an NPC never gets (--generative works here too)

    The real documentation is read with ri:
      rake ri && ri -d .ri HumanPlus::Human#surrender
  USAGE
  exit 1
end

def bar(level) = "#" * (level / 25)

def print_map
  puts "The Map of Consciousness (Hawkins)"
  puts
  MapOfConsciousness::LEVELS.to_a.reverse.each do |name, level|
    marker = level < MapOfConsciousness::COURAGE ? "program" : "state"
    puts format("  %-13s %4d  %-7s %s", name, level, marker, bar(level))
    puts "  #{'-' * 46} Courage: the threshold" if name == :courage
  end
  puts
  puts "Below 200 a feeling is a program — it runs you."
end

def print_npc(npc)
  puts "Human.default => #{npc.inspect}"
  puts
  puts format("  %-8s %5s  %-11s %-9s %s", "program", "level", "(map)", "pressure", "responds with")
  npc.programs.each do |p|
    puts format("  %-8s %5d  %-11s %-9d :%s", p.name, p.level, MapOfConsciousness.name_of(p.level), p.pressure, p.reaction)
  end
  puts
  puts "  calibration: #{npc.calibration} (below Courage — the firmware is in charge)"
  puts "  coping style: #{npc.coping_style} (factory default)"
  puts "  npc?: #{npc.npc?}"
end

def print_experience(npc, stimulus)
  reaction = npc.experience(stimulus)
  response = npc.last_response
  puts %(stimulus: "#{stimulus}")
  puts
  if response.nil?
    puts "  no program matches — the unprogrammed stimulus passes through."
    return
  end
  puts "  feeling:  #{response.name} (level #{response.level}, pressure now #{response.pressure} — suppression accumulates)"
  puts "  the mind: #{npc.mind.thoughts(response.name).first(3).map(&:inspect).join(', ')} ..."
  puts "  response: :#{reaction}"
end

def print_mind(npc, name, count)
  unless npc.respond_to?(name)
    abort "the default human runs no `#{name}` program (try: #{npc.programs.map(&:name).join(', ')})"
  end
  feeling = npc.public_send(name)
  supply = npc.mind.thoughts(name).count
  puts "#{name} (pressure #{feeling.pressure}) can generate #{supply} thoughts. The first #{count}:"
  puts
  npc.mind.thoughts(name).first(count).each { |t| puts "  #{t}" }
end

def run_stimuli(file)
  require "csv"
  failures = 0
  CSV.read(file, headers: true).each do |row|
    npc = NPC.new
    stimulus = row["stimulus"]
    reaction = npc.experience(stimulus)
    expected = row["expected_response"]&.to_sym

    ok = reaction == expected &&
         (expected.nil? || (npc.last_response.name == row["expected_feeling"].to_sym &&
                            npc.mind.thoughts(npc.last_response.name).first(50).include?(row["expected_thought"])))
    failures += 1 unless ok
    status = ok ? "PASS" : "FAIL"
    got = reaction.nil? ? "passes through" : "#{npc.last_response.name} -> :#{reaction}"
    puts format("  %-4s %-62s %s", status, %("#{stimulus}"), got)
  end
  puts
  puts failures.zero? ? "all stimuli behave as programmed." : "#{failures} failing."
  exit failures.zero? ? 0 : 1
end

def interactive_surrender(npc, name)
  unless npc.respond_to?(name)
    abort "the default human runs no `#{name}` program (try: #{npc.programs.map(&:name).join(', ')})"
  end
  feeling = npc.public_send(name)
  abort "`#{name}` is a state — there is no pressure to empty." if feeling.state?

  puts "#{name} — level #{feeling.level} (#{MapOfConsciousness.name_of(feeling.level)}), pressure #{feeling.pressure}"
  puts "Stay with the feeling. Don't suppress it, don't express it, don't escape it."
  puts

  npc.surrender(name) do |wave, remaining|
    print "  [Enter to stay with it] "
    $stdin.gets
    puts "  released #{wave} — #{remaining} unit#{'s' unless remaining == 1} of stored energy left"
  end

  puts
  puts "#{name} has run out. The program is uninstalled:"
  puts "  npc.respond_to?(:#{name})  # => #{npc.respond_to?(name)}"
  puts "  calibration: #{npc.calibration}"
end

def emancipate(npc)
  puts "Before: #{npc.inspect}"
  love_before = npc.love
  puts %(  "love", per the firmware: level #{love_before.level} (#{MapOfConsciousness.name_of(love_before.level)}), ) +
       %(responds with :#{love_before.reaction} — #{love_before.thought_seeds.first(2).join(' / ')})
  puts
  puts "Surrendering everything below Courage (200):"
  puts

  npc.programs.map(&:name).each do |name|
    waves = []
    npc.surrender(name) { |wave, _| waves << wave }
    puts format("  let go of %-8s waves: %-28s calibration: %d",
                "#{name}:", waves.join(" "), npc.calibration)
  end

  puts
  puts "After: #{npc.inspect}"
  puts "  emancipated? #{npc.emancipated?}   npc? #{npc.npc?}"
  puts
  puts "  What remains where `love` was:"
  love = npc.love
  puts "    level:          #{love.level} (#{MapOfConsciousness.name_of(love.level)})"
  puts "    unconditional?  #{love.unconditional?} — it needs nothing from the other"
  puts "    responds with:  :#{love.reaction}"
  puts "    the mind:       #{npc.mind.thoughts(:love).first(3).inspect} — quiet."
  puts
  puts "  npc.respond_to?(:fear)  # => #{npc.respond_to?(:fear)}"
  begin
    npc.fear
  rescue NoMethodError => e
    puts "  npc.fear                # => NoMethodError: #{e.message}"
  end
end

def print_town(stimulus, ticks, generative: false, chart_path: nil)
  town = Town.new(narrator: build_narrator(generative))
  chart = chart_path && Town::Chart.new(town, stimulus)
  puts "The town (data/town.csv):"
  town.residents.each do |r|
    note = r.aware? ? "reflects at #{r.awareness} thoughts on one subject" : "never looks — the firmware is in charge"
    puts format("  %-8s calibration %3d  %s", r.name, r.human.calibration, note)
  end
  puts
  puts %(the world incites: "#{stimulus}")
  puts

  town.run(stimulus, ticks: ticks) do |n, events|
    chart&.record(n, events)
    puts "tick #{n}"
    print_in_the_air(events) if generative
    events.each { |e| print_event(e) }
    puts
  end

  if town.quiet?
    puts "The town is quiet — nothing below Courage was left to pass it on."
  else
    puts "After #{ticks} ticks the town is still running. The pressure never left — it moved:"
  end
  town.residents.each do |r|
    top = r.human.programs.max_by(&:pressure)
    status = if top.nil?
               "no programs left"
             else
               "#{r.human.programs.size} programs installed, most pressurized: #{top.name} (#{top.pressure})"
             end
    puts format("  %-8s calibration %3d  %s", r.name, r.human.calibration, status)
    ledger = r.memory.grudges.map { |who, charge| "#{who} (#{charge})" }.join(", ")
    puts format("  %-8s holds it against: %s", "", ledger) unless ledger.empty?
  end
  return unless chart

  File.write(chart_path, chart.to_html)
  puts
  puts "The run, as a page: #{chart_path} — open it in a browser."
end

def print_event(e)
  case e
  when Town::Reacted
    at = e.witnessed.reaction ? "#{e.witnessed.actor}'s :#{e.witnessed.reaction}" : e.witnessed.actor
    puts format("  %-8s %s(%d)  pressure %-3d -> :%-12s at %s", e.actor, e.feeling, e.level, e.pressure, e.reaction, at)
  when Town::Reflected
    puts format("  %-8s reflects: %s", e.actor, e.insight)
    puts format("  %-8s lets go of %s  (waves: %s)  calibration: %d", "", e.feeling, e.waves.join(" "), e.calibration)
  when Town::Radiated
    puts format("  %-8s %s(%d) -> :%s — unconditional; witnessed with no trigger in it", e.actor, e.state, e.level, e.reaction)
  when Town::Unmoved
    puts format("  %-8s nothing hooks — the stimulus passes through", e.actor)
  end
end

def print_in_the_air(events)
  events.grep(Town::Reacted).map(&:witnessed).uniq(&:text).each do |w|
    source = w.reaction ? "#{w.actor}'s :#{w.reaction}" : w.actor
    puts %(  in the air (#{source}): "#{w.text}")
  end
end

def build_narrator(generative)
  return Town::Narrator.new unless generative

  require_relative "../lib/human_plus/generative_narrator"
  puts "The Narrator borrows a Mind (#{Town::GenerativeNarrator::MODEL}):"
  puts "perception is generated fresh, then hardens into habit."
  puts
  Town::GenerativeNarrator.new
end

def print_conversation(a, b, stimulus, turns, generative: false)
  town = Town.new(narrator: build_narrator(generative))
  pair = [a, b].map { |name| town.residents.find { |r| r.name == name } or abort "no resident named `#{name}` (the census: #{town.residents.map(&:name).join(', ')})" }
  before = pair.to_h { |r| [r.name, r.human.programs.sum(&:pressure)] }

  puts "#{a} and #{b}, at close range. The words are the Mind aloud;"
  puts "what travels is the tone."
  puts
  puts %(the world, to #{a}: "#{stimulus}")
  puts

  town.converse(a, b, stimulus, turns: turns).each do |e|
    case e
    when Town::Spoke
      voice = e.level >= MapOfConsciousness::COURAGE ? "#{e.feeling}(#{e.level}) — a state" : "#{e.feeling}(#{e.level}), pressure #{e.pressure}"
      puts format("  %-8s (%s): %s", e.speaker, voice, e.line.inspect)
      puts format("  %-8s  ...heard as: %s", "", e.heard_as)
    when Town::Reflected
      puts format("  %-8s reflects: %s", e.actor, e.insight)
      puts format("  %-8s lets go of %s  (waves: %s)  calibration: %d", "", e.feeling, e.waves.join(" "), e.calibration)
    when Town::FellSilent
      puts "  #{e.name} — nothing hooks; silence."
    end
    puts
  end

  pair.each do |r|
    other = (pair - [r]).first
    delta = r.human.programs.sum(&:pressure) - before[r.name]
    held = r.memory.against(other.name)
    note = if delta.positive?
             filed = held.positive? ? ", #{held} of it filed under #{other.name}" : ""
             "carries #{delta} more than they brought#{filed} — venting is not release"
           elsif delta.negative?
             "carries #{-delta} less than they brought — something ran out"
           else
             "carries nothing new"
           end
    puts format("  %-8s calibration %3d  %s", r.name, r.human.calibration, note)
  end
end

def sit_with(player, name)
  feeling = player.public_send(name)
  puts "  stay with it. no story, no name — just the stored energy. [Enter per wave]"
  player.surrender(name) do |wave, left|
    print "    released #{wave} — #{left} unit#{'s' unless left == 1} left "
    $stdin.gets or abort
  end
  puts "  #{name} has run out. you.respond_to?(:#{name})  # => false"
  puts "  calibration: #{player.calibration}"
  feeling
end

def player_turn(player, witnessed, program)
  source = witnessed.reaction ? "#{witnessed.actor}'s :#{witnessed.reaction}" : witnessed.actor
  puts
  puts %(  at you, from #{source}: "#{witnessed.text}")
  puts "  it fires: #{program.name} (#{program.level}, #{MapOfConsciousness.name_of(program.level)}), pressure #{program.pressure}"
  puts "  the mind: #{player.mind.thoughts(program.name).first(3).map(&:inspect).join(' · ')} ..."
  loop do
    print "  suppress, express, escape — or surrender?  [s/e/a/S] "
    case $stdin.gets&.strip
    when "s"
      program.suppress!
      puts "  pushed down. pressure #{program.pressure} — the mind will spend it."
      return program.reaction
    when "e"
      program.express!
      puts %(  you, aloud: "#{player.mind.thoughts(program.name).first}")
      puts "  vented — just enough to let the rest be suppressed. pressure #{program.pressure}."
      return program.reaction
    when "a"
      program.escape!
      puts "  the drink, the scroll, the busyness. nothing changes; it waits."
      return program.reaction
    when "S"
      sit_with(player, program.name)
      return nil # nothing runs; the town witnesses nothing
    when nil, "q"
      abort "\nyou left the town running. it will manage — it always does."
    end
  end
end

def reflect_menu(player)
  if player.programs.empty?
    puts "  nothing left to sit with."
    return
  end
  puts "  installed: #{player.programs.map { |p| "#{p.name}(#{p.pressure})" }.join(', ')}"
  print "  sit with which? "
  name = $stdin.gets&.strip.to_s
  return if name.empty?

  unless player.respond_to?(name) && player.public_send(name).program?
    puts "  you don't run a `#{name}` program."
    return
  end
  sit_with(player, name.to_sym)
end

def print_standing(you, player, town)
  puts "  calibration #{player.calibration}, #{player.programs.size} programs installed"
  ledger = town.residents.find { |r| r.name == you }.memory.grudges
  if ledger.empty?
    puts "  the ledger: empty."
  else
    puts "  the ledger: #{ledger.map { |who, c| "#{who} (#{c})" }.join(', ')}"
  end
  top = player.programs.max_by(&:pressure)
  puts "  loudest subject: #{top.name} — #{player.mind.thoughts(top.name).count} thoughts on it" if top
end

def live(stimulus, generative: false)
  you = (ENV["USER"] || "you").downcase
  player = NPC.new
  town = Town.new(narrator: build_narrator(generative))
  abort "the census already has a `#{you}`" if town.residents.any? { |r| r.name == you }

  puts "You wake up in the town as `#{you}`. You ship with the factory firmware —"
  puts "#{player.programs.size} programs you never chose, calibration #{player.calibration}. alice and bea never look;"
  puts "carol reflects, eventually. The difference is one thing only: when a program"
  puts "of yours fires, you get the question an NPC never gets."
  puts
  puts "Choices: [s]uppress  [e]xpress  [a] escape  [S]urrender — between ticks,"
  puts "[r] sit with any installed program, [l] your standing, [q] quit."
  puts

  town.settle(you, human: player) { |witnessed, program| player_turn(player, witnessed, program) }
  town.incite(stimulus)
  puts %(the world incites: "#{stimulus}")

  tick = 0
  loop do
    tick += 1
    puts
    puts "tick #{tick}"
    events = town.tick
    print_in_the_air(events) if generative
    events.each { |e| print_event(e) }

    break if player.emancipated?
    if town.quiet?
      puts
      puts "the town has gone quiet — nothing below Courage was left to pass it on."
      break
    end

    quitting = false
    loop do
      print "\n[Enter] next tick · [r]eflect · [l] standing · [q]uit  "
      case $stdin.gets&.strip
      when "r" then reflect_menu(player)
      when "l" then print_standing(you, player, town)
      when nil, "q" then quitting = true
      else break
      end
      break if quitting || player.emancipated?
    end
    break if quitting || player.emancipated?
  end

  puts
  if player.emancipated?
    love = player.love
    puts "Nothing installed calibrates below Courage (200). Emotional emancipation:"
    puts "  what remains: #{love.name}(#{love.level}) -> :#{love.reaction} — unconditional; it needs nothing from the town"
    puts "  the ledger:   empty — every grudge dissolved with its program"
    puts "  the mind:     #{player.mind.thoughts(:love).count} thoughts. quiet."
    puts "  you.npc?      #{player.npc?}"
    puts
    puts "The town keeps running. It no longer runs you."
  else
    print_standing(you, player, town)
  end
end

command, *rest = ARGV

case command
when "map"        then print_map
when "npc"        then print_npc(Human.default)
when "experience" then rest.empty? ? usage : print_experience(Human.default, rest.join(" "))
when "mind"       then rest.empty? ? usage : print_mind(Human.default, rest[0].to_sym, (rest[1] || 10).to_i)
when "test"       then run_stimuli(rest[0] || File.expand_path("../data/stimuli.csv", __dir__))
when "surrender"  then rest.empty? ? usage : interactive_surrender(Human.default, rest[0].to_sym)
when "emancipate" then emancipate(Human.default)
when "town"
  generative = !rest.delete("--generative").nil?
  chart_flag = rest.find { |arg| arg.start_with?("--chart") }
  rest.delete(chart_flag)
  chart_path = chart_flag && (chart_flag.split("=", 2)[1] || "town.html")
  print_town(rest[0] || "criticism lands on a mistake", (rest[1] || 12).to_i, generative:, chart_path:)
when "converse"
  generative = !rest.delete("--generative").nil?
  print_conversation(rest[0] || "alice", rest[1] || "bea",
                     rest[2] || "your partner doesn't text back — the absence of the beloved",
                     (rest[3] || 8).to_i, generative:)
when "live"
  generative = !rest.delete("--generative").nil?
  live(rest[0] || "criticism lands on a mistake", generative:)
else usage
end
